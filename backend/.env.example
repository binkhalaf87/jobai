# Application metadata exposed by the API.
APP_NAME=JobAI Backend
APP_VERSION=0.1.0

# API routing and environment mode.
API_PREFIX=/api/v1
ENVIRONMENT=development
DEBUG=false

# Required service configuration.
DATABASE_URL=postgresql://user:password@localhost:5432/jobai
# Optional until rewrite generation is enabled in your deployment.
OPENAI_API_KEY=sk-example
# Optional model override for resume rewrite generation.
OPENAI_REWRITE_MODEL=gpt-4o-mini
JWT_SECRET=replace-with-a-long-random-secret
# Comma-separated frontend origins allowed to call this API.
# In production this should be your Vercel app URL. Localhost is added automatically
# when ENVIRONMENT is not "production", so you usually do not need to repeat it here.
ALLOWED_ORIGIN=https://your-app.vercel.app
# Optional for future cache or queue features.
REDIS_URL=redis://localhost:6379/0
# Optional until Stripe billing is enabled.
STRIPE_SECRET_KEY=sk_test_example
# Optional until Paymob billing is enabled.
PAYMOB_API_KEY=live_or_test_secret_key
PAYMOB_HMAC_SECRET=paymob_webhook_hmac_secret
PAYMOB_PUBLIC_KEY=pk_live_or_test_example
PAYMOB_INTEGRATION_ID=1234567
# Optional when using Paymob's hosted iframe flow.
PAYMOB_IFRAME_ID=987654
# ── Object Storage (S3-compatible) ──────────────────────────────────────────
# Recommended for all persistent deployments (containers lose local files on restart).
# Supported providers: AWS S3, Cloudflare R2, MinIO, DigitalOcean Spaces, etc.
#
# Leave S3_BUCKET_NAME blank to fall back to local filesystem (development only).
S3_BUCKET_NAME=your-jobai-resumes-bucket
# Non-AWS providers require an endpoint URL, e.g.:
#   Cloudflare R2:  https://<account_id>.r2.cloudflarestorage.com
#   MinIO (local):  http://localhost:9000
S3_ENDPOINT_URL=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key

# Fallback local storage dir — only used when S3_BUCKET_NAME is not set.
RESUME_STORAGE_DIR=/var/app/data/resumes

# Local port for direct backend execution. Railway typically injects PORT automatically.
PORT=8000
